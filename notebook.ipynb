# ============================================
# CELDA 1: IMPORTAR LIBRERÍAS
# ============================================
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
from datetime import datetime

print('✓ Librerías importadas correctamente')

# ============================================
# CELDA 2: CARGAR DATOS DESDE GITHUB
# ============================================

# URL base de tu repositorio
base_url = 'https://raw.githubusercontent.com/ENERTEF/TEF-DHN-Service-1---Heating-Consumption-Optimisation/main/Datasets/'

# Lista de archivos (ajusta según los nombres reales)
archivos = [
    'Energía Contador Energía Fase 1 Central.csv',
    'Energía Contador Energía Fase 2 Central.csv',
    'Potencia Contador energía Caldera 1 Central.csv',
    'Potencia Contador Energía Fase 2.csv'
    # Añade más archivos según necesites
]

print('Cargando datos desde GitHub...')

# Cargar primer archivo para ver estructura
url_ejemplo = base_url + 'Energía Contador Energía Fase 1 Central.csv'
df_ejemplo = pd.read_csv(url_ejemplo)

print('\n=== ESTRUCTURA DEL DATASET ===')
print(f'Columnas: {df_ejemplo.columns.tolist()}')
print(f'\nPrimeras filas:')
print(df_ejemplo.head())

# ============================================
# CELDA 3: PROCESAR DATOS
# ============================================

# Cargar todos los archivos necesarios
print('\nCargando todos los archivos...')

# Ajusta según tu estructura real de datos
df_energia_f1 = pd.read_csv(base_url + 'Energía Contador Energía Fase 1 Central.csv')
df_energia_f2 = pd.read_csv(base_url + 'Energía Contador Energía Fase 2 Central.csv')
df_potencia_f1 = pd.read_csv(base_url + 'Potencia Contador energía Caldera 1 Central.csv')
df_potencia_f2 = pd.read_csv(base_url + 'Potencia Contador Energía Fase 2.csv')

# Combinar datos (ajusta según tu estructura)
# Asumiendo que todos tienen la misma columna de fecha
df = df_energia_f1.copy()
df['Energia_Fase1'] = df_energia_f1.iloc[:, 1]  # Ajusta índice de columna
df['Energia_Fase2'] = df_energia_f2.iloc[:, 1]
df['Potencia_Fase1'] = df_potencia_f1.iloc[:, 1]
df['Potencia_Fase2'] = df_potencia_f2.iloc[:, 1]

# Convertir fecha
df['fecha'] = pd.to_datetime(df.iloc[:, 0])
df = df.sort_values('fecha').reset_index(drop=True)
df['año'] = df['fecha'].dt.year
df['mes'] = df['fecha'].dt.month

# Calcular incrementos (variables acumuladas)
df['Energia_Fase1_Consumo'] = df['Energia_Fase1'].diff()
df['Energia_Fase2_Consumo'] = df['Energia_Fase2'].diff()
df['Energia_Total_Consumo'] = df['Energia_Fase1_Consumo'] + df['Energia_Fase2_Consumo']

# Sumar potencias
df['Potencia_Total'] = df['Potencia_Fase1'] + df['Potencia_Fase2']

# Limpiar datos
df = df[df['Energia_Total_Consumo'] > 0]
df = df[df['Potencia_Total'] > 0]

print(f'✓ Datos procesados: {len(df)} registros')
print(f'✓ Período: {df["fecha"].min()} a {df["fecha"].max()}')
print(f'✓ Años: {sorted(df["año"].unique())}')

# ============================================
# CELDA 4: CALCULAR UMBRALES Y % ERROR
# ============================================

# Estadísticas generales (5 años)
media_energia = df['Energia_Total_Consumo'].mean()
std_energia = df['Energia_Total_Consumo'].std()
umbral_energia = media_energia + (2 * std_energia)
porcentaje_error_energia = ((umbral_energia - media_energia) / media_energia) * 100

media_potencia = df['Potencia_Total'].mean()
std_potencia = df['Potencia_Total'].std()
umbral_potencia = media_potencia + (2 * std_potencia)
porcentaje_error_potencia = ((umbral_potencia - media_potencia) / media_potencia) * 100

print('\n=== UMBRAL GENERAL (2020-2024) ===')
print(f'\nENERGÍA:')
print(f'  Media: {media_energia:.2f} kWh')
print(f'  Desviación Estándar: {std_energia:.2f} kWh')
print(f'  Umbral (Media + 2σ): {umbral_energia:.2f} kWh')
print(f'  % Error: {porcentaje_error_energia:.2f}%')

print(f'\nPOTENCIA:')
print(f'  Media: {media_potencia:.2f} kW')
print(f'  Desviación Estándar: {std_potencia:.2f} kW')
print(f'  Umbral (Media + 2σ): {umbral_potencia:.2f} kW')
print(f'  % Error: {porcentaje_error_potencia:.2f}%')

# ============================================
# CELDA 5: TABLA DE UMBRALES
# ============================================

# Crear tabla de umbrales
tabla_umbrales = pd.DataFrame({
    'Variable': ['Energía Total', 'Potencia Total'],
    'Media': [media_energia, media_potencia],
    'Desviación Estándar': [std_energia, std_potencia],
    'Umbral Pico (2σ)': [umbral_energia, umbral_potencia],
    '% Error': [porcentaje_error_energia, porcentaje_error_potencia],
    'Unidad': ['kWh', 'kW']
})

print('\n=== TABLA DE UMBRALES ===')
print(tabla_umbrales.to_string(index=False))

# Guardar tabla
tabla_umbrales.to_csv('tabla_umbrales.csv', index=False)
print('\n✓ Tabla guardada como tabla_umbrales.csv')

# ============================================
# CELDA 6: UMBRALES MENSUALES
# ============================================

umbrales_mensuales = {}
meses_nombres = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic']

print('\n=== UMBRALES ESPECÍFICOS POR MES ===')
print(f'{"Mes":<5} {"Media (kWh)":<15} {"Umbral (kWh)":<15} {"% Error":<10} {"Dif vs General":<15}')
print('-' * 70)

for mes in range(1, 13):
    datos_mes = df[df['mes'] == mes]['Energia_Total_Consumo']
    
    media_mes = datos_mes.mean()
    std_mes = datos_mes.std()
    umbral_mes = media_mes + (2 * std_mes)
    porcentaje_error_mes = ((umbral_mes - media_mes) / media_mes) * 100
    diferencia_porcentaje = ((umbral_mes - umbral_energia) / umbral_energia) * 100
    
    umbrales_mensuales[mes] = {
        'mes_nombre': meses_nombres[mes-1],
        'media': media_mes,
        'std': std_mes,
        'umbral': umbral_mes,
        'porcentaje_error': porcentaje_error_mes
    }
    
    print(f'{meses_nombres[mes-1]:<5} {media_mes:>12.2f}   {umbral_mes:>12.2f}   {porcentaje_error_mes:>7.2f}%   {diferencia_porcentaje:>+7.2f}%')

# ============================================
# CELDA 7: TABLA RESUMEN ANUAL
# ============================================

# Calcular medias anuales
media_energia_anual = df.groupby('año')['Energia_Total_Consumo'].mean()
media_potencia_anual = df.groupby('año')['Potencia_Total'].mean()

# Crear tabla resumen
tabla_resumen = pd.DataFrame({
    'Año': media_energia_anual.index,
    'Energía Total Media (kWh)': media_energia_anual.values.round(2),
    'Potencia Total Media (kW)': media_potencia_anual.values.round(2)
})

# Calcular variación interanual
tabla_resumen['Variación Energía (%)'] = tabla_resumen['Energía Total Media (kWh)'].pct_change() * 100
tabla_resumen['Variación Potencia (%)'] = tabla_resumen['Potencia Total Media (kW)'].pct_change() * 100

tabla_resumen['Variación Energía (%)'] = tabla_resumen['Variación Energía (%)'].round(2)
tabla_resumen['Variación Potencia (%)'] = tabla_resumen['Variación Potencia (%)'].round(2)
tabla_resumen = tabla_resumen.fillna('-')

print('\n=== TABLA RESUMEN: MEDIA ANUAL (2020-2024) ===')
print(tabla_resumen.to_string(index=False))

# Guardar
tabla_resumen.to_csv('resumen_anual.csv', index=False)
print('\n✓ Tabla guardada como resumen_anual.csv')

# ============================================
# CELDA 8: GRÁFICO DE BARRAS - ENERGÍA Y POTENCIA POR AÑO
# ============================================

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))

años = media_energia_anual.index
colores_energia = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8']
colores_potencia = ['#FFB6C1', '#87CEEB', '#90EE90', '#FFD700', '#DDA0DD']

# Gráfico Energía
ax1.bar(años, media_energia_anual.values, color=colores_energia[:len(años)], 
        edgecolor='black', linewidth=2, width=0.6)
ax1.set_xlabel('Año', fontsize=14, fontweight='bold')
ax1.set_ylabel('Energía Total Media (kWh)', fontsize=14, fontweight='bold')
ax1.set_title('Consumo Medio Anual de Energía Total\n(Fase 1 + Fase 2)', 
              fontsize=16, fontweight='bold')
ax1.grid(axis='y', alpha=0.3, linestyle='--')
ax1.axhline(y=media_energia, color='red', linestyle='--', linewidth=2, 
            label=f'Media: {media_energia:.1f} kWh')
ax1.legend()

for año, valor in zip(años, media_energia_anual.values):
    ax1.text(año, valor + (max(media_energia_anual.values) * 0.02), 
             f'{valor:.1f}\nkWh', ha='center', va='bottom', 
             fontweight='bold', fontsize=11)

# Gráfico Potencia
ax2.bar(años, media_potencia_anual.values, color=colores_potencia[:len(años)], 
        edgecolor='black', linewidth=2, width=0.6)
ax2.set_xlabel('Año', fontsize=14, fontweight='bold')
ax2.set_ylabel('Potencia Total Media (kW)', fontsize=14, fontweight='bold')
ax2.set_title('Demanda Media Anual de Potencia Total\n(Fase 1 + Fase 2)', 
              fontsize=16, fontweight='bold')
ax2.grid(axis='y', alpha=0.3, linestyle='--')
ax2.axhline(y=media_potencia, color='red', linestyle='--', linewidth=2, 
            label=f'Media: {media_potencia:.1f} kW')
ax2.legend()

for año, valor in zip(años, media_potencia_anual.values):
    ax2.text(año, valor + (max(media_potencia_anual.values) * 0.02), 
             f'{valor:.1f}\nkW', ha='center', va='bottom', 
             fontweight='bold', fontsize=11)

plt.tight_layout()
plt.savefig('comparativa_anual_energia_potencia.png', dpi=300, bbox_inches='tight')
plt.show()

print('\n✓ Gráfico guardado como comparativa_anual_energia_potencia.png')

# ============================================
# CELDA 9: DETECTAR PICOS
# ============================================

# Aplicar umbrales mensuales
df['umbral_mes'] = df['mes'].map(lambda m: umbrales_mensuales[m]['umbral'])
df['media_mes'] = df['mes'].map(lambda m: umbrales_mensuales[m]['media'])
df['es_pico_mensual'] = df['Energia_Total_Consumo'] > df['umbral_mes']
df['porcentaje_error_dato'] = ((df['Energia_Total_Consumo'] - df['media_mes']) / df['media_mes']) * 100

# Contar picos
total_picos = df['es_pico_mensual'].sum()
porcentaje_picos = (total_picos / len(df)) * 100

print(f'\n=== DETECCIÓN DE PICOS ===')
print(f'Total de picos detectados: {total_picos}')
print(f'Porcentaje de datos con picos: {porcentaje_picos:.2f}%')

print('\nPicos por año:')
for año in sorted(df['año'].unique()):
    picos_año = df[(df['año'] == año) & (df['es_pico_mensual'])]
    print(f'  {año}: {len(picos_año)} picos')

# ============================================
# CELDA 10: SCATTER PLOT DE PICOS POR AÑO
# ============================================

fig, axes = plt.subplots(len(df['año'].unique()), 1, figsize=(14, 4*len(df['año'].unique())))
if len(df['año'].unique()) == 1:
    axes = [axes]

fig.suptitle('Detección de Picos de Energía por Mes y Año\n(Umbrales específicos por mes)', 
             fontsize=18, fontweight='bold', y=0.995)

años = sorted(df['año'].unique())
colores_años = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8']
meses_nombres_plot = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic']

for idx, (año, ax, color) in enumerate(zip(años, axes, colores_años)):
    df_año = df[df['año'] == año].copy()
    picos_año = df_año[df_año['es_pico_mensual'] == True]
    
    # Scatter plot: datos normales
    ax.scatter(df_año['mes'], df_año['Energia_Total_Consumo'], 
               alpha=0.3, s=20, color='lightgray', label='Datos normales')
    
    # Scatter plot: picos
    ax.scatter(picos_año['mes'], picos_año['Energia_Total_Consumo'], 
               alpha=0.8, s=100, color=color, edgecolors='black', linewidth=1.5,
               marker='o', label=f'Picos detectados ({len(picos_año)})', zorder=5)
    
    # Línea de umbral variable por mes
    meses_plot = range(1, 13)
    umbrales_plot = [umbrales_mensuales[m]['umbral'] for m in meses_plot]
    medias_plot = [umbrales_mensuales[m]['media'] for m in meses_plot]
    
    ax.plot(meses_plot, umbrales_plot, color='red', linestyle='--', 
            linewidth=2, label='Umbral por mes', drawstyle='steps-mid')
    ax.plot(meses_plot, medias_plot, color='green', linestyle='-', 
            linewidth=1.5, alpha=0.7, label='Media por mes', drawstyle='steps-mid')
    
    # Configuración
    ax.set_xlabel('Mes', fontsize=12, fontweight='bold')
    ax.set_ylabel('Energía (kWh)', fontsize=12, fontweight='bold')
    ax.set_title(f'Año {año} - {len(picos_año)} picos detectados', 
                 fontsize=14, fontweight='bold', pad=10)
    ax.set_xticks(range(1, 13))
    ax.set_xticklabels(meses_nombres_plot)
    ax.grid(True, alpha=0.3, linestyle='--')
    ax.legend(loc='upper right', fontsize=9)
    ax.set_xlim(0.5, 12.5)

plt.tight_layout()
plt.savefig('picos_energia_scatter_plot.png', dpi=300, bbox_inches='tight')
plt.show()

print('\n✓ Gráfico guardado como picos_energia_scatter_plot.png')

# ============================================
# CELDA 11: RESUMEN FINAL
# ============================================

print('\n' + '='*60)
print('ANÁLISIS COMPLETADO')
print('='*60)
print('\nArchivos generados:')
print('  ✓ tabla_umbrales.csv')
print('  ✓ resumen_anual.csv')
print('  ✓ comparativa_anual_energia_potencia.png')
print('  ✓ picos_energia_scatter_plot.png')
print('\nResultados principales:')
print(f'  - Umbral de energía: {umbral_energia:.2f} kWh ({porcentaje_error_energia:.1f}% sobre media)')
print(f'  - Umbral de potencia: {umbral_potencia:.2f} kW ({porcentaje_error_potencia:.1f}% sobre media)')
print(f'  - Total de picos detectados: {total_picos} ({porcentaje_picos:.2f}% de los datos)')
print(f'  - Período analizado: {df["fecha"].min().strftime("%Y-%m-%d")} a {df["fecha"].max().strftime("%Y-%m-%d")}')
print('\n' + '='*60)
